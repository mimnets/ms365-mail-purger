# ── Graph API credentials (for listing users/mailboxes)
# These must match the same tenant you add in the Settings UI
CLIENT_ID=your-app-client-id
CLIENT_SECRET=***
TENANT_ID=your-tenant-id
REDIRECT_URI=http://localhost:8000/api/auth/callback
FRONTEND_URL=http://localhost:3000

# ── Encryption master key (REQUIRED - generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
ENCRYPTION_KEY=change-me-to-a-random-64-char-hex-string

# ── Admin access (optional - for UI display)
ADMIN_EMAIL=your-admin@yourorg.com

# ── Redis
REDIS_URL=redis://redis:6379/0

# ── Database
DATABASE_URL=sqlite:///./data/purger.db

# ── CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
